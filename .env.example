LLM_API_KEY=
LLM_MODEL_NAME=deepseek-v4-pro
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# 推荐：按 Agent 角色拆模型。
# - Router / SkillSelection: 分类与匹配，优先快。
# - Generator(Maker): 回答、工具结果综合、RAG evidence synthesis，优先强。
# - Reviewer(Checker): 审查、挑错、边界判断，优先稳。
# - ResponseRenderer: 确定性代码渲染，不调用 LLM，不需要模型配置。

# Router 使用便宜、快、非 reasoning 的分类模型。
# 如使用千问百炼，填写 ROUTER_LLM_API_KEY/BASE_URL；未设置时复用通用 LLM_*。
ROUTER_LLM_API_KEY=
ROUTER_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ROUTER_LLM_MODEL_NAME=qwen-flash
ROUTER_LLM_TEMPERATURE=0
ROUTER_LLM_MAX_TOKENS=512
ROUTER_LLM_DISABLE_THINKING=true

# SkillSelectionPass 只负责从 Skill Index 选择 0-N 个 SKILL.md，用快模型即可。
SKILL_SELECTOR_LLM_API_KEY=
SKILL_SELECTOR_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SKILL_SELECTOR_LLM_MODEL_NAME=qwen-flash
SKILL_SELECTOR_LLM_TEMPERATURE=0
SKILL_SELECTOR_LLM_MAX_TOKENS=512
SKILL_SELECTOR_LLM_DISABLE_THINKING=true

# Maker Round 1: 默认走 non-thinking 快路径；被 Checker REJECT 后再升级 repair profile。
GENERATOR_LLM_MODEL_NAME=deepseek-v4-pro
GENERATOR_LLM_TEMPERATURE=0.3
GENERATOR_LLM_MAX_TOKENS=2048
GENERATOR_LLM_DISABLE_THINKING=true

# Maker Repair Round: 仅在 PreStop / Checker REJECT 后使用，可保留 thinking/strong profile。
GENERATOR_REPAIR_LLM_MODEL_NAME=deepseek-v4-pro
GENERATOR_REPAIR_LLM_TEMPERATURE=0.2
GENERATOR_REPAIR_LLM_MAX_TOKENS=3000
GENERATOR_REPAIR_LLM_DISABLE_THINKING=false

# Checker: 推荐千问 Plus，低温审查更快、更稳；需要更强审查可换 qwen-max。
REVIEWER_LLM_API_KEY=
REVIEWER_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
REVIEWER_LLM_MODEL_NAME=qwen-plus
REVIEWER_LLM_TEMPERATURE=0
REVIEWER_LLM_MAX_TOKENS=3072

MEM0_API_KEY=
