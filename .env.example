LLM_API_KEY=
LLM_MODEL_NAME=deepseek-v4-pro
LLM_BASE_URL=https://api.deepseek.com
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192

# Router 使用便宜、快、非 reasoning 的分类模型。
# 未设置 ROUTER_LLM_API_KEY/BASE_URL 时会复用 LLM_API_KEY/BASE_URL。
ROUTER_LLM_MODEL_NAME=deepseek-v4-flash
ROUTER_LLM_TEMPERATURE=0
ROUTER_LLM_MAX_TOKENS=512
ROUTER_LLM_DISABLE_THINKING=true

# 后续可按角色拆模型；未设置 API_KEY/BASE_URL 时复用通用 LLM_*。
GENERATOR_LLM_MODEL_NAME=deepseek-v4-pro
GENERATOR_LLM_TEMPERATURE=0.7
GENERATOR_LLM_MAX_TOKENS=8192

REVIEWER_LLM_MODEL_NAME=deepseek-v4-pro
REVIEWER_LLM_TEMPERATURE=0.3
REVIEWER_LLM_MAX_TOKENS=8192

LEAD_LLM_MODEL_NAME=deepseek-v4-pro
LEAD_LLM_TEMPERATURE=0.7
LEAD_LLM_MAX_TOKENS=4096

MEM0_API_KEY=
